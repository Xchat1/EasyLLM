# EasyLLM Configuration
# Copy this file to .env and modify as needed

# Local app
SERVER_PORT=8022
SERVER_HOST=127.0.0.1

# Debug mode (set to true for verbose logging)
DEBUG=false

# Data directory
# Leave empty to use the shared per-user app data directory.
DATA_DIR=

# Secret key (set a long random value if you want sessions to survive restarts)
SECRET_KEY=

# Default password (optional; leave empty to create it in the UI on first startup; minimum 8 chars)
DEFAULT_PASSWORD=

# Local SQLite database
# Leave empty to use DATA_DIR/easyllm.db.
DB_SQLITE_PATH=

# HTTP Proxy (optional)
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=7890
PROXY_USERNAME=
PROXY_PASSWORD=
